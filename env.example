# Copiá estas claves como variables de entorno en Railway (Settings > Variables).
# Nunca pongas el token real acá ni lo subas a git.

META_ACCESS_TOKEN=

# ID de la cuenta de anuncios, SIN el prefijo "act_". España y México
# comparten la misma cuenta (act_1919997195036045), así que va una sola vez.
META_AD_ACCOUNT_ID=1919997195036045
